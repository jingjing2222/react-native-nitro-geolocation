{
  "name": "react-native-nitro-geolocation",
  "version": "1.2.6",
  "description": "Nitro-powered native geolocation for modern React Native apps",
  "main": "src/index",
  "source": "src/index",
  "browser": "src/index.web.tsx",
  "react-native": "src/index.tsx",
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "browser": "./src/index.web.tsx",
      "react-native": "./src/index.tsx",
      "default": "./src/index.tsx"
    },
    "./compat": {
      "types": "./src/compat/index.tsx",
      "react-native": "./src/compat/index.tsx",
      "browser": "./src/compat/index.web.ts",
      "default": "./src/compat/index.tsx"
    },
    "./background": {
      "types": "./src/background/index.ts",
      "browser": "./src/background/index.web.ts",
      "react-native": "./src/background/index.ts",
      "default": "./src/background/index.ts"
    }
  },
  "codegenConfig": {
    "name": "NitroGeolocationSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "author": "jingjing2222",
  "license": "MIT",
  "keywords": [
    "react-native",
    "geolocation",
    "location",
    "gps",
    "ios",
    "android",
    "nitro",
    "nitro-modules",
    "jsi",
    "new-architecture",
    "fused-location",
    "geocoding",
    "heading",
    "expo-dev-client"
  ],
  "homepage": "https://react-native-nitro-geolocation.pages.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jingjing2222/react-native-nitro-geolocation.git"
  },
  "files": [
    "src",
    "nitrogen",
    "android/build.gradle",
    "android/gradle.properties",
    "android/CMakeLists.txt",
    "android/src/**/*",
    "ios/**/*.h",
    "ios/**/*.m",
    "ios/**/*.mm",
    "ios/**/*.cpp",
    "ios/**/*.swift",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx",
    "*.podspec",
    "README.md"
  ],
  "devDependencies": {
    "@granite-js/vitest": "1.0.23",
    "@react-native/babel-preset": "0.81.1",
    "@tsconfig/react-native": "^3.0.7",
    "@types/react": "^19.1.0",
    "@types/react-test-renderer": "^18.0.0",
    "react": "19.1.0",
    "react-native": "0.81.1",
    "react-native-nitro-modules": "0.35.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.75.0",
    "react-native-nitro-modules": "*"
  },
  "sideEffects": false,
  "create-react-native-library": {
    "languages": "kotlin-swift",
    "type": "nitro-module",
    "version": "0.54.3"
  }
}
